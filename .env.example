# ── Azure SQL ──────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=kissv1
AZURE_SQL_USER=kissv1admin
AZURE_SQL_PASSWORD=YourStrongPassword123!
AZURE_SQL_PORT=1433

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=replace-with-random-secret
AUTH_MICROSOFT_ENTRA_ID_ID=your-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-client-secret-value
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0

# ── App ────────────────────────────────────────────────────────────────────
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
